<Window x:Class="CPU_Scheduler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CPU_Scheduler"
        mc:Ignorable="d"
        Title="CPU Scheduler Simulator" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Modern Purple Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4F46E5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Green Go/Run Button Style -->
        <Style x:Key="ModernButtonGreen" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#10B981"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#047857"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Smooth Input TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#6366F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Smooth Combo Box Style Approximation -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Input Label Style -->
        <Style TargetType="TextBlock" x:Key="InputLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="CPU Scheduler Simulator" FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Design, test, and visualize operating system CPU scheduling algorithms." 
                       FontSize="15" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Controls Panel -->
        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.04" Color="Black" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <StackPanel Margin="0,0,25,15">
                        <TextBlock Text="PROCESS ID" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="InputPID" Width="110"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,25,15">
                        <TextBlock Text="BURST TIME" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="InputBurst" Width="110"/>
                    </StackPanel>

                    <StackPanel x:Name="PriorityPanel" Margin="0,0,25,15">
                        <TextBlock Text="PRIORITY" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="InputPriority" Width="90"/>
                    </StackPanel>

                    <StackPanel x:Name="QuantumPanel" Margin="0,0,25,15">
                        <TextBlock Text="QUANTUM" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="InputQuantum" Width="90" Text="2"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,25,15">
                        <TextBlock Text="ALGORITHM" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="AlgoSelector" Width="200" SelectedIndex="0" SelectionChanged="AlgoSelector_SelectionChanged_1" Height="36">
                            <ComboBoxItem Content="FCFS"/>
                            <ComboBoxItem Content="SJF (Non-Preemptive)"/>
                            <ComboBoxItem Content="SJF (Preemptive)"/>
                            <ComboBoxItem Content="Priority (Preemptive)"/>
                            <ComboBoxItem Content="Priority (Non-Preemptive)"/>
                            <ComboBoxItem Content="Round Robin"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Content="+ Add Process" Click="AddProcess_Click" Style="{StaticResource ModernButton}" 
                            Margin="0,0,0,15" VerticalAlignment="Bottom" Height="36" Padding="20,0"/>
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,15">
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20,8" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TIME: " FontSize="20" FontWeight="SemiBold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TimeLabel" Text="00:00" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="Startmaya" Content="▶ RUN ALGORITHM" Click="StartBtn_Click" 
                            Style="{StaticResource ModernButtonGreen}" Height="45" FontSize="15" Padding="25,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Process DataGrid Container -->
        <Border Grid.Row="2" Background="White" CornerRadius="16" Margin="0,0,0,25" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.04" Color="Black" Direction="270"/>
            </Border.Effect>
            <DataGrid x:Name="ProcessGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      BorderThickness="0" Background="Transparent" RowHeight="45"
                      ColumnHeaderHeight="50" HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#F1F5F9" VerticalGridLinesBrush="Transparent">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#F1F5F9"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Foreground" Value="#334155"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PROCESS ID" Binding="{Binding ProcessID}" Width="*"/>
                    <DataGridTextColumn Header="ARRIVAL TIME" Binding="{Binding ArrivalTime}" Width="*"/>
                    <DataGridTextColumn Header="INITIAL BURST" Binding="{Binding BurstTime}" Width="*"/>
                    <DataGridTextColumn Header="REMAINING" Binding="{Binding RemainingBurstTime}" Width="*"/>
                    <DataGridTextColumn Header="PRIORITY" Binding="{Binding Priority}" Width="*"/>
                    <DataGridTextColumn Header="TURNAROUND" Binding="{Binding TurnaroundTime}" Width="*"/>
                    <DataGridTextColumn Header="WAITING" Binding="{Binding WaitingTime}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Visual Timeline Header & Averages -->
        <Grid Grid.Row="3" Margin="5,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="VISUAL TIMELINE" 
               FontWeight="Bold" 
               Foreground="#475569" 
               FontSize="14" 
               VerticalAlignment="Center"/>

            <Border Grid.Column="1" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="6" Padding="15,6" Margin="0,0,10,0">
                <TextBlock x:Name="AvgWaitText" Text="Avg Wait: 0.0s" FontSize="14" FontWeight="SemiBold" Foreground="#4F46E5"/>
            </Border>
            
            <Border Grid.Column="2" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="6" Padding="15,6">
                <TextBlock x:Name="AvgTurnText" Text="Avg Turnaround: 0.0s" FontSize="14" FontWeight="SemiBold" Foreground="#4F46E5"/>
            </Border>
        </Grid>

        <!-- Visual Timeline Container -->
        <Border Grid.Row="4" Background="#0F172A" CornerRadius="16" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="10" Opacity="0.15" Color="Black" Direction="270"/>
            </Border.Effect>
            <!-- A subtle inner glow could be achieved with another border, but keeping simple here -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="10">
                <StackPanel x:Name="GanttContainer" Orientation="Horizontal" VerticalAlignment="Center"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
