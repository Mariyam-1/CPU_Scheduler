<Window x:Class="CPU_Scheduler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CPU_Scheduler"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <Border Background="#F3F3F3" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PID:" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="InputPID" Width="60" VerticalAlignment="Center"/>

                <TextBlock Text="Burst:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBox x:Name="InputBurst" Width="60" VerticalAlignment="Center"/>

                <Button Content="Add Process" Click="AddProcess_Click" Margin="20,0" Padding="10,2"/>

                <Separator Width="20" Background="Transparent"/>
                <TextBlock Text="Priority:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBox x:Name="InputPriority" Width="40" VerticalAlignment="Center"/>

                <TextBlock Text="Algorithm:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <ComboBox x:Name="AlgoSelector" Width="100" VerticalAlignment="Center" SelectedIndex="0" SelectionChanged="AlgoSelector_SelectionChanged">
                    <ComboBoxItem Content="FCFS"/>
                    <ComboBoxItem Content="SJF (Non-Preemptive)"/>
                    <ComboBoxItem Content="SJF (Preemptive)"/>
                    <ComboBoxItem Content="Priority"/>
                </ComboBox>
                
                <Button x:Name="Startmaya" Content="START SCHEDULER" Click="StartBtn_Click" 
                        Background="Green" Foreground="White" FontWeight="Bold" Padding="15,5"/>

                <TextBlock x:Name="TimeLabel" Text="Time: 0s" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" Margin="30,0"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="ProcessGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessID}" Width="100"/>

                <DataGridTextColumn Header="Initial Burst" Binding="{Binding BurstTime}" Width="150"/>

                <DataGridTextColumn Header="Remaining Time" Binding="{Binding RemainingBurstTime}" Width="150"/>

                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Text="Live Gantt Chart" Grid.Row="2" Margin="0,10,0,5" FontWeight="Bold"/>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="GanttContainer" Orientation="Horizontal" Background="#222" Height="80"/>
        </ScrollViewer>
    </Grid>
</Window>
